---
// Projects.astro — Portfolio section
//
// ─────────────────────────────────────────────────────────────────────────────
// HOW TO ADD / EDIT PROJECTS
// ─────────────────────────────────────────────────────────────────────────────
//
// FEATURED PROJECT (the large case-study card at the top):
//   Edit the `featured` object below. Set `image` to a path inside /public/images/
//   or use null to show a placeholder block.
//
// SECONDARY PROJECTS (the 3-column grid below):
//   Add objects to the `secondary` array. Each card shows a number, category,
//   icon name (Material Symbols), title, description, tech chips, and a link.
//
//   icon   — any Google Material Symbol name, e.g. "cloud_queue", "terminal",
//             "database", "code", "settings", "storage", "hub"
//
//   github — string URL or null (hides the link when null) 
//   live   — string URL or null
//
// ─────────────────────────────────────────────────────────────────────────────

interface Project {
  id:          string;
  number:      string;
  title:       string;
  category:    string;
  description: string;
  longDescription?: string;
  tech:        string[];
  github:      string | null;
  live:        string | null;
  image:       string | null;
}

const projects: Project[] = [
  {
    id:          'ReWear-Website',
    number:      '01',
    category:    'Full-stack',
    title:       'ReWear Website',
    description: "ReWear is a web-based platform that makes sustainable fashion more accessible and engaging.",
    longDescription: "This is a Project for a course called Proyek Perangkat Lunak (PPL). This project thought me a lesson in project development and also how to do SCRUM methodologies for project development.",
    tech:        ['Laravel', 'PHP', 'SCRUM', 'Jira'],
    github:      "https://github.com/ReWear-GROUP-C/Rewear-Website",
    live:        null,
    image:       "ReWearWebsite",
  },
  {
    id:          'cloud-computing-project',
    number:      '02',
    category:    'Infrastructure',
    title:       'Cloud Computing Course Project',
    description: 'Making 2 Web Server instances with Load Balancer in AWS',
    longDescription: "This project made for a course called Cloud Computing. This project taught me a lesson how to make AWS instances and how to do Load Balancing and also how to manage the infrastructure. The website might be gone so check on my github for the website that is used in the project so that the load balancing in work is visible.",
    tech:        ['AWS', 'EC2', 'AWS RDS', 'Apache2', 'Load Balancer'],
    github:      "https://github.com/IqbalAbhipraya/cloud-computing-tubes-website",
    live:        "http://tubes-alb-1967647789.us-east-1.elb.amazonaws.com",
    image:       'CloudFinPro',
  }
];
---

<!-- Link Material Symbols for icons -->
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
/>

<section id="work" aria-labelledby="work-heading">
  <div class="section-wrap projects-inner">

    <!-- Section header -->
    <header class="projects-header reveal">
      <span class="eyebrow">Portfolio</span>
      <h2 id="work-heading" class="projects-title">Projects</h2>
    </header>

    <!-- ── Projects List ─────────────────────────────── -->
    <div class="projects-list">
      {projects.map((project, index) => (
        <div class={`featured-group reveal ${index % 2 !== 0 ? 'alternate' : ''}`}>
          <div class="featured-grid">
            <!-- Vertical label -->
            <div class="featured-label-col" aria-hidden="true">
              <span class="vertical-label">{project.category}</span>
            </div>

            <!-- Main card -->
            <div 
              class="featured-card project-card" 
              data-project-id={project.id}
              data-title={project.title}
              data-category={project.category}
              data-description={project.longDescription || project.description}
              data-tech={project.tech.join(',')}
              data-github={project.github || ''}
              data-live={project.live || ''}
              data-image={project.image ? `/project-image/${project.image}.webp` : ''}
              role="button"
              tabindex="0"
              aria-label={`View details for ${project.title}`}
            >
              <div class="featured-card-inner">
                <!-- Text side -->
                <div class="featured-text">
                  <div>
                    <span class="project-eyebrow">
                      {project.number} · {project.category}
                    </span>
                    <h3 class="featured-title">{project.title}</h3>
                    <p class="featured-desc">{project.description}</p>
                  </div>

                  <!-- Tech chips -->
                  <div class="chip-row" role="list" aria-label="Tech stack">
                    {project.tech.map(t => (
                      <span role="listitem" class="chip">{t}</span>
                    ))}
                  </div>

                  <!-- Links (stop propagation so clicking links doesn't open modal) -->
                  {(project.github || project.live) && (
                    <div class="featured-links">
                      {project.github && (
                        <a href={project.github} class="text-link skill-underline project-external-link" target="_blank" rel="noopener noreferrer">
                          GitHub
                          <span class="material-symbols-outlined" aria-hidden="true">arrow_outward</span>
                        </a>
                      )}
                      {project.live && (
                        <a href={project.live} class="text-link skill-underline project-external-link" target="_blank" rel="noopener noreferrer">
                          Live Demo
                          <span class="material-symbols-outlined" aria-hidden="true">visibility</span>
                        </a>
                      )}
                    </div>
                  )}
                </div>

                <!-- Image / placeholder -->
                <div class="featured-image-wrap">
                  {project.image ? (
                    <img
                      src={`/project-image/${project.image}.webp`}
                      alt={`${project.title} preview`}
                      class="featured-img"
                      loading="lazy"
                    />
                  ) : (
                    <div class="featured-placeholder" aria-hidden="true">
                      <span class="placeholder-label">Add project image to /public/project-image/</span>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- ── Project Detail Modal ─────────────────────────────── -->
    <dialog id="project-modal" class="project-modal">
      <div class="modal-backdrop"></div>
      <div class="modal-container">
        <button class="modal-close" aria-label="Close modal">
          <span class="material-symbols-outlined">close</span>
        </button>
        <div class="modal-content">
          <div class="modal-image-wrap">
            <img id="modal-img" src="" alt="" class="modal-img" style="display: none;" />
            <div id="modal-placeholder" class="featured-placeholder" aria-hidden="true">
               <span class="placeholder-label">Add project image to /public/project-image/</span>
            </div>
          </div>
          <div class="modal-body">
            <div class="modal-header">
              <span id="modal-category" class="project-eyebrow"></span>
              <h3 id="modal-title" class="modal-title"></h3>
            </div>
            <div class="modal-main">
              <div class="modal-sidebar">
                <div class="sidebar-block">
                  <h4 class="modal-subtitle">Technologies</h4>
                  <div id="modal-tech" class="chip-row"></div>
                </div>
                <div class="sidebar-block" id="modal-links-container">
                  <h4 class="modal-subtitle">Links</h4>
                  <div class="modal-links" id="modal-links"></div>
                </div>
              </div>
              <div class="modal-details">
                <h4 class="modal-subtitle">About the project</h4>
                <p id="modal-desc" class="modal-desc-text"></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </dialog>

  </div>
</section>

<script>
  // Scroll reveal
  const els = document.querySelectorAll('.reveal');
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    els.forEach(el => io.observe(el));
  } else {
    els.forEach(el => el.classList.add('is-visible'));
  }

  // Modal Logic
  const modal = document.getElementById('project-modal');
  const closeBtn = modal?.querySelector('.modal-close');
  const cards = document.querySelectorAll('.project-card');

  // Elements to populate
  const modalTitle = document.getElementById('modal-title');
  const modalCategory = document.getElementById('modal-category');
  const modalDesc = document.getElementById('modal-desc');
  const modalTech = document.getElementById('modal-tech');
  const modalLinks = document.getElementById('modal-links');
  const modalLinksContainer = document.getElementById('modal-links-container');
  const modalImg = document.getElementById('modal-img');
  const modalPlaceholder = document.getElementById('modal-placeholder');

  cards.forEach(card => {
    card.addEventListener('click', (e) => {
      // Don't open modal if clicking an external link
      if (e.target.closest('.project-external-link')) {
        return;
      }

      const title = card.getAttribute('data-title') || '';
      const category = card.getAttribute('data-category') || '';
      const desc = card.getAttribute('data-description') || '';
      const techStr = card.getAttribute('data-tech') || '';
      const github = card.getAttribute('data-github') || '';
      const live = card.getAttribute('data-live') || '';
      const image = card.getAttribute('data-image') || '';

      // Populate text
      if (modalTitle) modalTitle.textContent = title;
      if (modalCategory) modalCategory.textContent = category;
      if (modalDesc) modalDesc.textContent = desc;

      // Populate tech
      if (modalTech) {
        modalTech.innerHTML = '';
        if (techStr) {
          const techArr = techStr.split(',');
          techArr.forEach(t => {
            const span = document.createElement('span');
            span.className = 'chip';
            span.textContent = t;
            modalTech.appendChild(span);
          });
        }
      }

      // Populate links
      if (modalLinks && modalLinksContainer) {
        modalLinks.innerHTML = '';
        if (github || live) {
          modalLinksContainer.style.display = 'block';
          
          if (github) {
            const gitLink = document.createElement('a');
            gitLink.href = github;
            gitLink.className = 'btn-secondary btn-small';
            gitLink.target = '_blank';
            gitLink.rel = 'noopener noreferrer';
            gitLink.innerHTML = 'GitHub <span class="material-symbols-outlined" style="font-size: 16px;" aria-hidden="true">arrow_outward</span>';
            modalLinks.appendChild(gitLink);
          }

          if (live) {
            const liveLink = document.createElement('a');
            liveLink.href = live;
            liveLink.className = 'btn-primary btn-small';
            liveLink.target = '_blank';
            liveLink.rel = 'noopener noreferrer';
            liveLink.innerHTML = 'Live Demo <span class="material-symbols-outlined" style="font-size: 16px;" aria-hidden="true">visibility</span>';
            modalLinks.appendChild(liveLink);
          }
        } else {
          modalLinksContainer.style.display = 'none';
        }
      }

      // Populate image
      if (image && modalImg && modalPlaceholder) {
        modalImg.src = image;
        modalImg.alt = `${title} preview`;
        modalImg.style.display = 'block';
        modalPlaceholder.style.display = 'none';
      } else if (modalImg && modalPlaceholder) {
        modalImg.style.display = 'none';
        modalPlaceholder.style.display = 'flex';
      }

      // Open Modal
      document.body.style.overflow = 'hidden'; // lock scroll
      modal?.showModal();
    });
  });

  const closeModal = () => {
    modal?.close();
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeModal);

  // Close when clicking backdrop
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      closeModal();
    }
  });
</script>

<style>
  #work {
    padding: 96px 0;
  }

  .projects-inner {
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* ── Section header ─────────────────────────── */
  .projects-header { margin-bottom: 0; }
  .projects-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 8vw, 72px);
    font-weight: 600;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    line-height: 1.0;
  }

  /* ── Projects List ────────────────────────────── */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 20px; /* Adjust this value for more/less margin between projects */
  }

  /* ── Featured: outer grid ───────────────────── */
  .featured-group { width: 100%; }
  .featured-grid {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 32px;
    align-items: start;
  }

  /* Vertical label */
  .featured-label-col {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 48px;
  }
  .vertical-label {
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    white-space: nowrap;
  }

  /* Main card */
  .featured-card {
    background-color: var(--surface-low);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 48px;
    transition: border-color var(--transition), transform 0.3s ease;
    cursor: pointer;
  }
  .featured-card:hover { 
    transform: translateY(-2px);
    border-color: var(--primary);
  }
  .featured-card-inner {
    display: flex;
    gap: 48px;
    align-items: center;
  }
  
  .featured-group.alternate .featured-card-inner {
    flex-direction: row-reverse;
  }

  /* Text side */
  .featured-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .project-eyebrow {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--primary);
    display: block;
    margin-bottom: 10px;
  }
  .featured-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin-bottom: 16px;
    line-height: 1.1;
  }
  .featured-desc {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Tech chips */
  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chip-row--sm { gap: 6px; }
  .chip--sm { font-size: 10px; padding: 3px 10px; }

  /* Links */
  .featured-links {
    display: flex;
    gap: 32px;
    padding-top: 8px;
  }
  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-primary);
    transition: color var(--transition);
  }
  .text-link .material-symbols-outlined { font-size: 16px; }
  .text-link:hover { color: var(--primary); }
  .text-link--sm { font-size: 11px; }
  .text-link--sm .material-symbols-outlined { font-size: 14px; }
  .text-link--muted { color: var(--text-muted); cursor: default; }

  /* Image / placeholder */
  .featured-image-wrap {
    flex: 1;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 2px;
    overflow: hidden;
    background-color: var(--surface-high);
    transition: box-shadow var(--transition-slow);
  }
  .featured-card:hover .featured-image-wrap {
    box-shadow: 0 12px 40px rgba(30, 27, 23, 0.12);
  }
  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(30%);
    transition: filter var(--transition-slow);
  }
  .featured-card:hover .featured-img { filter: grayscale(0%); }

  .featured-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--surface-container) 0%, var(--surface-high) 100%);
  }
  .placeholder-label {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--text-muted);
    text-align: center;
    padding: 0 24px;
  }

  /* ── Modal Styles ─────────────────────────── */
  .project-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90vw;
    max-width: 900px;
    max-height: 90vh;
    border: none;
    background: transparent;
    padding: 0;
    margin: 0;
    z-index: 1000;
  }
  .project-modal::backdrop {
    background: rgba(51, 48, 43, 0.6);
    backdrop-filter: blur(8px);
  }
  
  .modal-container {
    position: relative;
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    display: flex;
    flex-direction: column;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }
  
  .modal-close {
    position: absolute;
    top: 24px;
    right: 24px;
    background: var(--surface-container);
    border: 1px solid var(--border);
    color: var(--text-primary);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: all var(--transition);
  }
  .modal-close:hover {
    background: var(--primary);
    color: var(--on-primary);
    border-color: var(--primary);
  }
  
  .modal-content {
    display: flex;
    flex-direction: column;
  }
  
  .modal-image-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--surface-high);
    position: relative;
  }
  .modal-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .modal-body {
    padding: 48px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .modal-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 24px;
  }
  
  .modal-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 600;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    line-height: 1.1;
    margin-top: 8px;
  }

  .modal-main {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 48px;
  }

  .modal-sidebar {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .sidebar-block {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .modal-subtitle {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }
  
  .modal-desc-text {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-top: 16px;
  }

  .modal-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 1024px) {
    .featured-card-inner { flex-direction: column !important; gap: 32px; }
    .featured-grid { grid-template-columns: 1fr; }
    .featured-label-col { display: none; }
  }
  @media (max-width: 768px) {
    .modal-main { grid-template-columns: 1fr; gap: 32px; }
    .modal-sidebar { flex-direction: row; flex-wrap: wrap; justify-content: space-between; }
    .sidebar-block { flex: 1; min-width: 150px; }
  }
  @media (max-width: 640px) {
    #work { padding: 64px 0; }
    .featured-card { padding: 28px; }
    .projects-inner { gap: 40px; }
    .modal-body { padding: 32px 24px; }
    .modal-close { top: 16px; right: 16px; }
  }
</style>

<style is:global>
  /* Global styles for dynamically injected elements (modal chips and buttons) */
  .chip {
    padding: 6px 14px;
    background-color: var(--surface-container);
    border: 1px solid var(--border);
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-primary);
    border-radius: 100px;
    display: inline-block;
  }

  .btn-small {
    padding: 10px 24px !important;
    font-size: 12px !important;
    width: fit-content;
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    gap: 8px;
    line-height: 1;
  }
</style>
